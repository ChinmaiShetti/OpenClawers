# ============================================================
# OpenClaw — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ============================================================

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///./openclaw.db
# For production Postgres:
# DATABASE_URL=postgresql://user:password@localhost:5432/openclaw

# ── Qdrant Vector DB ─────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=openclaw_memories

# ── LLM Providers ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
OPENAI_API_KEY=sk-...          # used only for embeddings (text-embedding-3-small)

# ── MCP Integrations ─────────────────────────────────────────
NOTION_TOKEN=secret_...
NOTION_DATABASE_ID=...

SLACK_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C...

GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-username
GITHUB_REPO=your-repo

# Google Calendar — path to downloaded credentials JSON
GOOGLE_CREDENTIALS_JSON=./credentials.json
GOOGLE_CALENDAR_ID=primary

# ── WhatsApp ─────────────────────────────────────────────────
WHATSAPP_API_KEY=...
WHATSAPP_PHONE_NUMBER_ID=...
WHATSAPP_TARGET_PHONE=+91...    # your number for demo nudges

# ── Service URLs (used internally between services) ──────────
BACKEND_URL=http://localhost:8000
AI_ENGINE_URL=http://localhost:9000

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_AI_URL=http://localhost:9000

# ── Auth (future) ────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
